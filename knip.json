{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "next.config.ts",
    "src/sw.ts",
    "src/mdx-components.tsx",
    "src/app/**/{page,layout,not-found,error,loading,sitemap,robots,manifest,viewport}.ts*",
    "src/lib/supabase/middleware.ts",
    "src/app/api/**/*.ts",
    "scripts/*.{mjs,cjs,js}"
  ],
  "project": ["src/**/*.{ts,tsx,js,jsx}", "scripts/**/*.{mjs,cjs,js}"],
  "ignore": ["**/*.stories.tsx", "**/*.test.tsx", "src/data/database.types.ts"],
  "ignoreDependencies": [
    "@tailwindcss/typography",
    "depcheck",
    "esbuild-wasm",
    "rimraf",
    "tailwindcss",
    "postcss",
    "supabase"
  ]
}
