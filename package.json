{
  "name": "tom-and-jerry-chase-wiki",
  "version": "0.1.0",
  "private": true,
  "description": "专为《猫和老鼠手游》玩家打造的数据查询网站",
  "homepage": "https://tjwiki.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/asHOH/Tom-and-jerry-chase-wiki.git"
  },
  "bugs": {
    "url": "https://github.com/asHOH/Tom-and-jerry-chase-wiki/issues"
  },
  "funding": {
    "type": "patreon",
    "url": "https://patreon.com/asHOH"
  },
  "author": "asHOH",
  "license": "(CC-BY-4.0 AND GPL-3.0-or-later)",
  "keywords": [
    "tom-and-jerry",
    "mobile-game",
    "wiki",
    "nextjs",
    "react"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-doc-pages.mjs && next build --webpack && node scripts/run-image-optimization.cjs",
    "build:debug": "node scripts/generate-doc-pages.mjs && next build --debug --webpack && node scripts/run-image-optimization.cjs",
    "generate:changelogs": "node scripts/generate-changelogs.mjs",
    "report:character-relations": "node scripts/report-character-relations.mjs",
    "set-runtime:edge": "node scripts/set-api-runtime.mjs edge",
    "set-runtime:node": "node scripts/set-api-runtime.mjs nodejs",
    "build:skip-images": "node scripts/generate-doc-pages.mjs && next build --webpack",
    "start": "next start",
    "lint": "eslint . --cache",
    "lint:fast": "oxlint",
    "lint:fix": "eslint . --fix --cache",
    "lint:staged": "eslint --fix --max-warnings=0 --cache",
    "prettier:check": "prettier --check . --cache",
    "prettier:fix": "prettier --write . --cache",
    "prettier:staged": "prettier --write --ignore-unknown --cache",
    "format": "npm run prettier:fix && npm run lint:fix",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false --maxWorkers=50%",
    "test:changed": "jest --onlyChanged --passWithNoTests",
    "clean": "rimraf .next out coverage",
    "analyze": "cross-env ANALYZE=true npm run build",
    "audit": "npm audit --audit-level=moderate",
    "outdated": "npm outdated",
    "size": "size-limit",
    "update-readme": "node scripts/update-readme-acknowledgments.mjs",
    "cleanup-temp": "rimraf scripts/temp",
    "pre-push:force-fast": ".husky/pre-push-fast",
    "pre-push:force-full": "cross-env FORCE_FULL_PREPUSH=true .husky/pre-push",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.3.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@google/genai": "^1.47.0",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "@marsidev/react-turnstile": "^1.5.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/env": "^16.2.2",
    "@next/mdx": "^16.2.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@serwist/next": "^9.5.7",
    "@supabase/ssr": "0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/core": "3.21.0",
    "@tiptap/extension-image": "3.21.0",
    "@tiptap/extension-link": "3.21.0",
    "@tiptap/extension-table": "3.21.0",
    "@tiptap/extension-table-cell": "3.21.0",
    "@tiptap/extension-table-header": "3.21.0",
    "@tiptap/extension-table-row": "3.21.0",
    "@tiptap/extension-text-align": "3.21.0",
    "@tiptap/pm": "3.21.0",
    "@tiptap/react": "3.21.0",
    "@tiptap/starter-kit": "3.21.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "esbuild-wasm": "^0.27.4",
    "json5": "^2.2.3",
    "lodash-es": "^4.17.22",
    "motion": "^12.38.0",
    "next": "^16.2.2",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "pinyin-pro": "^3.28.0",
    "proxy-compare": "^3.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1",
    "serwist": "^9.5.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "usehooks-ts": "^3.1.1",
    "valtio": "^2.3.1",
    "valtio-persist": "^2.2.4",
    "web-push": "^3.6.7",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@next/bundle-analyzer": "^16.2.2",
    "@size-limit/file": "^12.0.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "cross-env": "^10.1.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jiti": "^2.6.1",
    "knip": "^5.86.0",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.57.0",
    "postcss": "^8.5.8",
    "postcss-preset-env": "^10.6.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "schema-dts": "^1.1.5",
    "server-only": "^0.0.1",
    "size-limit": "^12.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "trim-newlines": "^3.0.1",
    "js-yaml": "^4.1.1"
  },
  "size-limit": [
    {
      "path": ".next/static/chunks/main-*.js",
      "limit": "60 KB",
      "gzip": true
    },
    {
      "path": ".next/static/chunks/framework-*.js",
      "limit": "80 KB",
      "gzip": true
    },
    {
      "path": ".next/static/chunks/[0-9]*-*.js",
      "limit": "260 KB",
      "gzip": true
    }
  ],
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --deny-warnings",
      "prettier --write --ignore-unknown --cache"
    ],
    "**/*.{json,css,md,mdx,html,yml,yaml}": "prettier --write --ignore-unknown --cache"
  },
  "depcheck": {
    "ignores": [
      "@tailwindcss/postcss",
      "@types/jest",
      "@types/node",
      "depcheck",
      "eslint",
      "eslint-config-next",
      "jest-environment-jsdom",
      "postcss",
      "rimraf",
      "tailwindcss",
      "ts-node"
    ]
  }
}
